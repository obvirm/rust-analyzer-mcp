## 🔒 1. Error Handling & Recovery

### LSP Crash Recovery
```rust
impl LspClient {
    pub async fn start_with_recovery(ra_path: &Path, workspace_root: &Path, max_retries: u32) -> Result<Self> {
        let mut last_error = None;
        
        for attempt in 0..max_retries {
            match Self::start(ra_path, workspace_root).await {
                Ok(client) => return Ok(client),
                Err(e) => {
                    last_error = Some(e);
                    log::warn!("LSP startup attempt {} failed: {}", attempt + 1, e);
                    if attempt < max_retries - 1 {
                        tokio::time::sleep(Duration::from_secs(2_u64.pow(attempt))).await;
                    }
                }
            }
        }
        Err(last_error.unwrap())
    }
}
```

### Graceful Degradation & Error Recovery Pattern
- Timeout handling untuk setiap LSP request (default: 30s)
- Retry logic untuk transient errors
- Automatic LSP restart on crash

```rust
impl McpServer {
    async fn execute_with_retry<F, T>(&self, operation: F, max_retries: u32) -> Result<T>
    where F: async Fn() -> Result<T>,
    {
        let mut last_error = None;
        
        for attempt in 0..max_retries {
            match operation().await {
                Ok(result) => return Ok(result),
                Err(e) => {
                    last_error = Some(e.clone());
                    if !is_retryable_error(&e) {
                        return Err(e);
                    }
                    if attempt < max_retries - 1 {
                        self.restart_lsp_client().await?;
                    }
                }
            }
        }
        Err(last_error.unwrap())
    }
    
    async fn restart_lsp_client(&self) -> Result<()> {
        *self.lsp_client.write().await = None;
        if let Some(root) = &self.project_root {
            let client = LspClient::start(&self.ra_path, Path::new(root)).await?;
            *self.lsp_client.write().await = Some(Arc::new(client));
        }
        Ok(())
    }
}

fn is_retryable_error(e: &anyhow::Error) -> bool {
    e.downcast_ref::<std::io::Error>()
        .map(|e| e.kind() == std::io::ErrorKind::BrokenPipe || e.kind() == std::io::ErrorKind::ConnectionReset)
        .unwrap_or(false)
        || e.to_string().contains("LSP not initialized")
}
