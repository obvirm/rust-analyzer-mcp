pub struct HealthStatus {
    pub server_version: String,
    pub uptime_seconds: u64,
    pub rust_analyzer: RaHealth,
    pub lsp_connection: LspHealth,
    pub cache_stats: CacheHealth,
}

pub const HEALTH_RESOURCE: &str = "health://status";

pub async fn get_health_status(state: &AppState) -> HealthStatus {
    let ra_version = updater::version::current_version().await;
    let latest = updater::github::get_latest_release_tag().await.ok();
    
    let lsp = state.lsp_client.read().await;
    
    HealthStatus {
        server_version: env!("CARGO_PKG_VERSION").to_string(),
        uptime_seconds: state.start_time.elapsed().as_secs(),
        rust_analyzer: RaHealth {
            path: state.ra_path.display().to_string(),
            version: ra_version,
            up_to_date: ra_version.as_ref() == latest.as_ref(),
        },
        lsp_connection: LspHealth {
            connected: lsp.is_some(),
            workspace_loaded: lsp.as_ref().map(|c| c.is_ready()).unwrap_or(false),
        },
        cache_stats: CacheHealth { enabled: state.config.cache.enabled },
    }
}

